38 \u0449\u043e \u0437\u0430\u043f\u0443\u0441\u043a\u0430\u044e\u0442\u044c\u0441\u044f \u0432\u043d\u043e\u0447\u0456.\n\nAnthropic \u0431\u0443\u0434\u0443\u0454 AI, \u044f\u043a\u0438\u0439 \u043d\u0435 \u0437\u0430\u0431\u0443\u0432\u0430\u0454.\n\n\u0406 \u0446\u0435 \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \"\u043f\u0430\u043c'\u044f\u0442\u044c \u0447\u0430\u0442\u0443\". \u0426\u0435 \u0440\u0456\u0432\u0435\u043d\u044c \u0433\u043b\u0438\u0431\u0448\u0435: AI, \u044f\u043a\u0438\u0439 \u0437\u043d\u0430\u0454 \u0427\u041e\u041c\u0423 \u0432\u0430\u0448\u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u043e\u0431\u0440\u0430\u043b\u0430 PostgreSQL, \u0447\u043e\u043c\u0443 \u0432\u0456\u0434\u043c\u043e\u0432\u0438\u043b\u0438\u0441\u044c \u0432\u0456\u0434 \u043c\u0456\u043a\u0440\u043e\u0441\u0435\u0440\u0432\u0456\u0441\u0456\u0432, \u0447\u043e\u043c\u0443 \u0440\u0435\u0432\u0440\u0430\u0439\u0442\u043d\u0443\u043b\u0438 \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0456\u044e \u0432 \u043b\u044e\u0442\u043e\u043c\u0443. \u041a\u043e\u043d\u0442\u0435\u043a\u0441\u0442 \u0440\u0456\u0448\u0435\u043d\u044c, \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u043a\u043e\u0434.\n\n\u0417\u0430\u0440\u0430\u0437 \u0446\u0435 \u0454 \u0442\u0456\u043b\u044c\u043a\u0438 \u0434\u043b\u044f \u043e\u0434\u043d\u043e\u0433\u043e \u0440\u043e\u0437\u0440\u043e\u0431\u043d\u0438\u043a\u0430. \u0410\u043b\u0435 \u0443\u044f\u0432\u0456\u0442\u044c, \u0449\u043e \u0446\u0435\u0439 AI \u043f\u0430\u043c'\u044f\u0442\u0430\u0454 \u0440\u0456\u0448\u0435\u043d\u043d\u044f \u0432\u0441\u0456\u0454\u0457 \u043a\u043e\u043c\u0430\u043d\u0434\u0438. \u041d\u043e\u0432\u0438\u0439 \u0434\u0435\u0432\u0435\u043b\u043e\u043f\u0435\u0440 \u043f\u0440\u0438\u0445\u043e\u0434\u0438\u0442\u044c \u043d\u0430 \u043f\u0440\u043e\u0454\u043a\u0442 \u2014 \u0456 \u0437\u0430\u043c\u0456\u0441\u0442\u044c \u0434\u0432\u043e\u0445 \u0442\u0438\u0436\u043d\u0456\u0432